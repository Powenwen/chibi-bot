# =================================
# DISCORD BOT CONFIGURATION
# =================================

# Discord Bot Token (Required)
# Get from: https://discord.com/developers/applications
TOKEN=your_discord_bot_token_here

# Discord Application ID (Required)
# Found in your Discord application's "General Information" tab
# Note: The dashboard also uses this (or DISCORD_CLIENT_ID)
CLIENT_ID=your_discord_application_id_here

# Discord Client Secret (Required for dashboard OAuth)
# Get from: https://discord.com/developers/applications -> OAuth2
# Only needed if you're running the dashboard
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Test Guild ID (Development Only)
# Your Discord server ID for testing commands
GUILD_ID=your_test_guild_id_here

# Environment Mode
# Options: development, production, testing
NODE_ENV=development

# =================================
# DATABASE CONFIGURATION
# =================================

# MongoDB Configuration (Required)
# Local: mongodb://localhost:27017/chibibase
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/chibibase
MONGO_URI=mongodb://localhost:27017/chibibase
MONGO_DB_NAME=chibibase

# MongoDB Authentication (Optional)
# Only needed if your MongoDB instance requires authentication
MONGO_USERNAME=
MONGO_PASSWORD=

# =================================
# REDIS CONFIGURATION (OPTIONAL)
# =================================

# Redis Cache Configuration
# Improves bot performance significantly
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis Database Number (Optional)
REDIS_DB=0

# =================================
# FEATURE FLAGS
# =================================

# Core Systems
ENABLE_WELCOME_SYSTEM=true
ENABLE_STICKY_MESSAGES=true
ENABLE_AUTO_REACTIONS=true
ENABLE_SUGGESTION_SYSTEM=true
ENABLE_MODERATION_SYSTEM=true
ENABLE_AUTO_MODERATION=true

# Development Features
ENABLE_HEALTH_CHECKS=true
ENABLE_DEBUG_LOGGING=false
ENABLE_PERFORMANCE_MONITORING=true

# =================================
# PERFORMANCE SETTINGS
# =================================

# Cache TTL (Time To Live) in seconds
MESSAGE_CACHE_TTL=3600          # 1 hour
USER_DATA_CACHE_TTL=7200        # 2 hours
AUTO_REACTION_CACHE_TTL=1800    # 30 minutes
GUILD_CONFIG_CACHE_TTL=1800     # 30 minutes

# Rate Limiting
API_RATE_LIMIT=50               # Requests per minute
COMMAND_COOLDOWN=3              # Seconds between commands per user

# =================================
# COMMAND REGISTRATION
# =================================

# Guild vs Global Commands
# true = Register commands only in test guild (faster for development)
# false = Register commands globally (slower, for production)
USE_GUILD_COMMANDS=true

# Target Guild for Development
TARGET_GUILD_ID=your_test_guild_id_here

# Force Command Re-registration
# Set to true to force update commands on bot startup
FORCE_REGISTER_COMMANDS=false

# =================================
# MODERATION SETTINGS
# =================================

# Auto-Moderation Thresholds
SPAM_THRESHOLD=5                # Messages per 10 seconds
MENTION_SPAM_LIMIT=5           # Max mentions per message
DUPLICATE_MESSAGE_LIMIT=3       # Identical messages threshold

# Warning System
MAX_WARNINGS_BEFORE_ACTION=3    # Warnings before escalation
WARNING_EXPIRY_DAYS=30         # Days before warnings expire

# =================================
# LOGGING & MONITORING
# =================================

# Log Levels: error, warn, info, debug
LOG_LEVEL=info

# Error Reporting
ERROR_THRESHOLD=50              # Max errors before alert
HEALTH_CHECK_INTERVAL=300000   # 5 minutes in milliseconds

# Performance Monitoring
MONITOR_MEMORY_USAGE=true
MEMORY_LIMIT_MB=512            # MB before warning

# =================================
# OPTIONAL INTEGRATIONS
# =================================

# Webhook URLs for notifications (Optional)
ERROR_WEBHOOK_URL=
STATUS_WEBHOOK_URL=

# =================================
# ADVANCED CONFIGURATION
# =================================

# Bot Activity/Presence
BOT_ACTIVITY_TYPE=WATCHING      # PLAYING, STREAMING, LISTENING, WATCHING, COMPETING
BOT_ACTIVITY_NAME=for /help     # Activity description
BOT_STATUS=online               # online, idle, dnd, invisible

# Timezone
TIMEZONE=UTC                    # Timezone for timestamps

# Language/Locale
DEFAULT_LANGUAGE=en-US          # Default bot language
DATE_FORMAT=MM/DD/YYYY         # Date format preference

# =================================
# SECURITY SETTINGS
# =================================

# Rate Limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW=60           # seconds
RATE_LIMIT_MAX_REQUESTS=30     # requests per window

# Command Security
REQUIRE_PERMISSIONS=true        # Enforce Discord permissions
OWNER_ONLY_COMMANDS=true       # Enable owner-only commands
OWNER_USER_IDS=your_user_id_here # Comma-separated list

# Data Privacy
DELETE_USER_DATA_ON_LEAVE=false # Auto-delete user data when leaving server
ANONYMIZE_LOGS=true            # Remove sensitive data from logs