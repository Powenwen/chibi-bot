{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "rootDir": ".",
    "outDir": "./dist",
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.d.ts"
  ]
}
